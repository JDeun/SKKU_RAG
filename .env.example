# AgenticRAG 환경변수 설정
# 이 파일을 .env로 복사한 후 실제 API 키를 입력하세요.

# ───────────────────────────────────────────────────────────
# LLM API 키 (Gemini 필수 / Groq는 Gemini 사용량 제한 시 fallback)
# ───────────────────────────────────────────────────────────

# Google Gemini API 키 (필수)
# https://aistudio.google.com/app/apikey 에서 발급 (무료)
GOOGLE_API_KEY=your_google_api_key_here

# Groq API 키 (선택, Gemini 사용량 초과·오류 시 자동 fallback)
# https://console.groq.com/ 에서 발급 (무료 티어 제공)
# 설정해두면 Gemini가 실패할 때 Groq의 모델로 자동 전환됩니다.
GROQ_API_KEY=your_groq_api_key_here

# ───────────────────────────────────────────────────────────
# 데이터 소스 API 키
# ───────────────────────────────────────────────────────────

# Materials Project API 키 (선택)
# https://next-gen.materialsproject.org/api 에서 발급
MATERIALS_PROJECT_API_KEY=your_materials_project_api_key_here

# Crossref mailto (선택, 하지만 권장)
# API 사용 시 연락 가능한 이메일 주소
CROSSREF_MAILTO=your.email@example.com

# Brave Search API 키 (선택, 웹 검색용 / 없으면 DuckDuckGo로 자동 전환)
# https://api.search.brave.com/ 에서 발급 (정책 변화로 무료 티어 없어짐)
BRAVE_API_KEY=your_brave_api_key_here

# ───────────────────────────────────────────────────────────
# Ollama 설정 (임베딩 모델용)
# ───────────────────────────────────────────────────────────

# Ollama 서버 URL (기본값: http://localhost:11434)
# 원격 Ollama 서버 사용 시에만 변경하세요.
# OLLAMA_BASE_URL=http://localhost:11434
